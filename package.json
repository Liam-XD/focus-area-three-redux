    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.8.0",
    "dotenv": "^17.4.2",
    "playwright-bdd": "^8.5.1"
  }
